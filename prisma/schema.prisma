generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  birthDate String?
  phone     String?
  gender    String?
  aiLogs    AiLog[]
    
  // Controle de Acesso e Planos
  plan_tier String   @default("standard")
  role      String   @default("USER") // ADMIN ou USER
  plan      String   @default("PERFORMANCE") // FREE, ELITE, VIP
  active    Boolean  @default(true)
    
  // Dados Rápidos (Cache)
  currentWeight Float? // Peso atualizado pelo check-in ou avaliação
    
  // Gamification & Notificações
  currentXP Int      @default(0)
  pushToken String?  // Para notificações OneSignal/Expo
    
  // Foto de perfil e Avaliação/Check-in
  photoUrl        String?
  evaluationUrl   String?  // Link da Avaliação em PDF (Google Drive/Canva)
  nextCheckInDate DateTime? // 🔥 NOVO: Data do próximo check-in definida manualmente pelo Admin
  disableCheckIn  Boolean  @default(false) // 🔥 NOVO: Desativa a cobrança de check-in
  dietGoal        String   @default("NONE") // 🔥 NOVO: Sugestão Alimentar do Aluno
  goal            String?
  level           String?

  // 🔥 CHAVE DO MÓDULO DE DIETA (Toggle do Admin)
  dietModule      Boolean  @default(false)

  createdAt DateTime @default(now())

  // 🔥 MULTI-TENANT (SISTEMA DE MÚLTIPLOS COACHES)
  // Define a qual treinador este aluno pertence
  coachId   String?
  coach     User?    @relation("CoachStudents", fields: [coachId], references: [id], onDelete: SetNull)
  students  User[]   @relation("CoachStudents")

  // 🔥 CRIAÇÕES EXCLUSIVAS DO COACH (O Muro de Separação)
  createdExercises  Exercise[]        @relation("CoachExercises")
  createdTemplates  WorkoutTemplate[] @relation("CoachTemplates")
  createdNotices    Notice[]          @relation("CoachNotices")
  createdContents   Content[]         @relation("CoachContents")
  createdCollections TemplateCollection[] @relation("CoachCollections") // 🔥 NOVO: Pastas/Coleções do Coach

  // Relacionamentos do Aluno
  workouts   Workout[]
  anamneses  Anamnese[]
  history    WorkoutHistory[] 
  assessments Assessment[]        
  checkIns   CheckIn[]
  diets      Diet[] // 🔥 NOVO: Relacionamento com as Dietas
  
  // PA FLIX & Comunidade
  contentLikes   ContentLike[]
  contentComments ContentComment[]
  contentCompletions ContentCompletion[] // Histórico de aulas assistidas
  unlockedContents ContentAccess[]       // Relação de conteúdos VIP liberados manualmente
}

model Exercise {
  id            String   @id @default(uuid())
  name          String   
  category      String
  videoUrl      String?
  instructions  String?
  createdAt     DateTime @default(now())
    
  // 🔥 ISOLAMENTO: A qual Coach este exercício pertence?
  coachId       String?
  coach         User?    @relation("CoachExercises", fields: [coachId], references: [id], onDelete: Cascade)

  // Relacionamentos
  workoutExercises WorkoutExercise[] 
  asSubstitute     WorkoutExercise[] @relation("SubstituteRelation")

  // 🔥 Permite que a Adri e o Paulo tenham um exercício com o mesmo nome, com vídeos diferentes.
  @@unique([name, coachId])
}

model Workout {
  id        String    @id @default(uuid())
  name      String    
  goal      String?   
  level     String?   
  isVisible Boolean   @default(true)
    
  // Planejamento
  startDate DateTime? @default(now()) 
  endDate   DateTime? 
  archived  Boolean   @default(false) 

  // 🔥 NOVO: MODELO DO TREINO (CARGA vs BASE) 🔥
  workoutModel String @default("CARGA")
    
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  createdAt DateTime  @default(now())
}

model WorkoutExercise {
  id        String   @id @default(uuid())
  workoutId String
  workout   Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
    
  // Exercício Principal
  exerciseId String
  exercise   Exercise @relation(fields: [exerciseId], references: [id])
    
  // Exercício Substituto (Opcional)
  substituteId String?
  substitute   Exercise? @relation("SubstituteRelation", fields: [substituteId], references: [id])

  restTime    Int      @default(60)
  title       String?  
  sets        Int      @default(3)
  reps        String   @default("12") 
  notes       String?  
  technique   String?  
  day         String   @default("A") 
  order       Int      @default(0) 

  observation String?  
}

model Anamnese {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    
  // Dados Físicos
  peso            Float
  altura          Float
  imc             Float?    
  aguaIdeal       Float?    
    
  // Objetivos
  objetivo        String    
  nivel           String    
    
  // Rotina de Treino
  frequencia      Int       
  tempoDisponivel Int      @default(60) 
    
  // Saúde (Arrays)
  limitacoes      String[]  
  cirurgias       String[]  
  equipamentos    String[]  

  // 🔥 NUTRIÇÃO E DIETA (Campos opcionais para o plano Elite) 🔥
  mealsPerDay     Int?      // Quantas vezes prefere comer ao dia (2 a 8)
  allergies       String?   @db.Text // Alergias e Intolerâncias
  foodPreferences String?   @db.Text // Gostos e Preferências
  foodAversions   String?   @db.Text // O que não gosta de comer
  supplements     String?   @db.Text // Suplementos que já utiliza
  wakeUpTime      String?   // Horário que acorda
  sleepTime       String?   // Horário que dorme
  workTime        String?   // Horário de trabalho
  trainTime       String?   // Horário do treino
    
  createdAt       DateTime @default(now())
}

// 🔥 NOVO: MOTOR DE DIETAS (PADRÃO ELITE) 🔥
model Diet {
  id            String    @id @default(uuid())
  userId        String    
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Nível 1: Rota Expressa (Upload)
  pdfUrl        String?   
  
  // Nível 2: Dieta Dinâmica no App
  name          String    @default("Plano Alimentar")
  goal          String?   // Ex: Emagrecimento, Hipertrofia
  
  // Macros Totais Diários
  totalKcal     Float?
  totalProtein  Float?
  totalCarbs    Float?
  totalFats     Float?
  
  // Recomendações Gerais
  waterIntake   String?   // Ex: 3 Litros
  freeMeal      String?   // Ex: 1x por semana
  generalNotes  String?   @db.Text // Suplementação base, finais de semana, etc.
  
  isActive      Boolean   @default(true)
  meals         Meal[]    
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Meal {
  id        String     @id @default(uuid())
  dietId    String
  diet      Diet       @relation(fields: [dietId], references: [id], onDelete: Cascade)
  name      String     // Ex: Café da Manhã, Almoço, Pré-Treino
  time      String?    // Ex: 08:00
  order     Int        @default(0) 
  notes     String?    @db.Text // Instruções de preparo, ex: "Faça uma crepioca com o ovo e a tapioca"
  
  items     FoodItem[]
}

model FoodItem {
  id                  String   @id @default(uuid())
  mealId              String
  meal                Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  
  name                String   // Ex: Arroz Branco, Frango, Pão Integral
  amount              Float    // Ex: 100, 2, 1
  unit                String   // Ex: gramas, ml, fatia, colher de sopa, unidade, xícara
  
  // Macros do item (opcional, para compor o total)
  protein             Float?
  carbs               Float?
  fats                Float?
  calories            Float?

  // 🔥 O SEGREDO DO "OU": Itens com o mesmo ID neste campo são substitutos entre si
  substitutionGroupId String?  
}

// 🔥 COLEÇÕES DE TEMPLATES (A "Netflix do Fitness")
model TemplateCollection {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#22c55e") // Verde oficial como padrão
  createdAt DateTime @default(now())

  // ISOLAMENTO: A qual Coach pertence esta coleção?
  coachId   String?
  coach     User?    @relation("CoachCollections", fields: [coachId], references: [id], onDelete: Cascade)

  // Relação: Quais templates estão dentro desta pasta?
  templates WorkoutTemplate[]
}

model WorkoutTemplate {
  id        String   @id @default(uuid())
  name      String   
  goal      String   
  level     String   
  data      String    @db.Text 
  createdAt DateTime @default(now())

  // ISOLAMENTO: A qual Coach este template pertence?
  coachId   String?
  coach     User?    @relation("CoachTemplates", fields: [coachId], references: [id], onDelete: Cascade)

  // 🔥 NOVO: Coleção/Pasta a qual este template pertence
  collectionId String?
  collection   TemplateCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

// Histórico de Treinos (Gamification)
model WorkoutHistory {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    
  name             String   
  workoutName      String? 
  date             DateTime @default(now())
  xpEarned         Int      @default(0)
  duration         Int?     
  progressions     Int      @default(0) 

  rpe              Int?     
  feedback         String?  

  details          ExerciseHistory[]
}

model ExerciseHistory {
  id               String         @id @default(uuid())
  workoutHistoryId String
  workoutHistory   WorkoutHistory @relation(fields: [workoutHistoryId], references: [id], onDelete: Cascade)
    
  exerciseId       String
  exerciseName     String
    
  setNumber        Int
  weight           Float  
  reps             String 
}

// Avaliação Física (Pollock/Dobras)
model Assessment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
    
  // Nível 1: Básico
  weight          Float    
  height          Float?    
  photos          String[] 
    
  // Nível 2: Medidas (cm)
  neck            Float?    
  shoulders       Float?    
  chest           Float?    
  arms            Float?    
  forearms        Float?    
  waist           Float?    
  abdomen         Float?    
  hips            Float?    
  thighs          Float?    
  calves          Float?    
    
  // Nível 3: Composição (mm)
  method          String?  // "POLLOCK_7", "BIO", "MANUAL"
    
  foldTriceps     Float?
  foldSubscapular Float?
  foldChest       Float?
  foldAxillary    Float?
  foldSuprailiac  Float?
  foldAbdominal   Float?
  foldThigh       Float?
    
  // Resultados
  bodyFat         Float?    
  visceralFat     Float?    
  muscleMass      Float?    
    
  notes           String?   
  createdAt       DateTime @default(now())
}

// Check-in Diário/Semanal
model CheckIn {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
    
  weight      Float?
  feedback    String?  
    
  photoFront  String?  
  photoBack   String?
  coachFeedback  String?   // feedback do coach
  allowMarketing Boolean @default(false)  // autorização de marketing
  photoSide   String?
  extraPhotos String[] // 🔥 NOVO: Array para salvar os links das fotos extras
    
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

// Mural de Avisos do Admin
model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  active    Boolean  @default(true)
  date      DateTime @default(now())

  // 🔥 ISOLAMENTO: De qual Coach é este aviso?
  coachId   String?
  coach     User?    @relation("CoachNotices", fields: [coachId], references: [id], onDelete: Cascade)
}

model AiLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  question  String
  answer    String
  createdAt DateTime @default(now())
}

// 🔥 PA FLIX (Área de Conteúdo e Comunidade Unificada)
model Content {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?  @db.Text
    
  category    String   // Ex: 'TECNICA', 'MINDSET', 'NUTRICAO'
    
  type        String   @default("video") // "video", "ebook", "audio"
  isVIP       Boolean  @default(false)   // Controle de bloqueio
  
  videoUrl    String?  
  pdfUrl      String?  
  audioUrl    String?  
  thumbUrl    String?  
  duration    String?  
    
  createdAt   DateTime @default(now())

  // 🔥 ISOLAMENTO: A qual Coach pertence este E-book/Vídeo?
  coachId     String?
  coach       User?    @relation("CoachContents", fields: [coachId], references: [id], onDelete: Cascade)
    
  // Relações Sociais e Acesso
  likes       ContentLike[]
  comments    ContentComment[]
  completions ContentCompletion[] 
  unlockedFor ContentAccess[]
}

model ContentLike {
  id        String   @id @default(uuid())
    
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
    
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model ContentComment {
  id        String   @id @default(uuid())
  text      String   @db.Text
    
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
    
  createdAt DateTime @default(now())
}

model ContentCompletion {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}

model ContentAccess {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}