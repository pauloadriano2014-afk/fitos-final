// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  password        String
  name            String?
  birthDate       String?
  phone           String?
  gender          String?
  aiLogs          AiLog[]
  dailyCheckins   DailyCheckin[]
  dietFeedbacks   DietFeedback[]
  npsRequested    Boolean  @default(false) // Gatilho manual para disparar o NPS
  
  // Controle de Acesso e Planos
  plan_tier       String   @default("standard")
  role            String   @default("USER") // ADMIN, USER ou COACH
  plan            String   @default("PERFORMANCE") // FREE, ELITE, VIP
  active          Boolean  @default(true)
  
  // Dados Rápidos (Cache)
  currentWeight   Float? 
  
  // Gamification & Notificações
  currentXP       Int      @default(0)
  pushToken       String?  
  
  // Foto de perfil e Avaliação/Check-in
  photoUrl        String?
  evaluationUrl   String?  
  nextCheckInDate DateTime? 
  disableCheckIn  Boolean  @default(false) 
  dietGoal        String   @default("NONE") 
  goal            String?
  level           String?

  // 🔥 CHAVE DO MÓDULO DE DIETA (Toggle do Admin)
  dietModule      Boolean  @default(false)

  createdAt       DateTime @default(now())

  // 🔥 MULTI-TENANT (SISTEMA DE MÚLTIPLOS COACHES)
  // Define a qual treinador (de treinos) este aluno pertence
  coachId         String?
  coach           User?    @relation("CoachStudents", fields: [coachId], references: [id], onDelete: SetNull)
  students        User[]   @relation("CoachStudents")

  // 🔥 NOVO: Define a qual NUTRICIONISTA este aluno pertence
  nutritionistId  String?
  nutritionist    User?    @relation("NutritionistStudents", fields: [nutritionistId], references: [id], onDelete: SetNull)
  dietStudents    User[]   @relation("NutritionistStudents")

  // 🔥 CRIAÇÕES EXCLUSIVAS DO COACH (O Muro de Separação)
  createdExercises  Exercise[]          @relation("CoachExercises")
  createdTemplates  WorkoutTemplate[]   @relation("CoachTemplates")
  createdNotices    Notice[]            @relation("CoachNotices")
  createdContents   Content[]           @relation("CoachContents")
  createdCollections TemplateCollection[] @relation("CoachCollections") 

  // Relacionamentos do Aluno
  workouts        Workout[]
  anamneses       Anamnese[]
  history         WorkoutHistory[] 
  assessments     Assessment[]        
  checkIns        CheckIn[]
  diets           Diet[] 
  
  // PA FLIX & Comunidade
  contentLikes      ContentLike[]
  contentComments   ContentComment[]
  contentCompletions ContentCompletion[] 
  unlockedContents  ContentAccess[]      

  // 🔥 NOVO: Relacionamento de Pesquisas de Satisfação
  surveys           SatisfactionSurvey[]
}

model Exercise {
  id              String   @id @default(uuid())
  name            String   
  category        String
  videoUrl        String?
  instructions    String?
  createdAt       DateTime @default(now())
  
  // 🔥 ISOLAMENTO: A qual Coach este exercício pertence?
  coachId         String?
  coach           User?    @relation("CoachExercises", fields: [coachId], references: [id], onDelete: Cascade)

  // Relacionamentos
  workoutExercises WorkoutExercise[] 
  asSubstitute     WorkoutExercise[] @relation("SubstituteRelation")

  // 🔥 Permite que a Adri e o Paulo tenham um exercício com o mesmo nome, com vídeos diferentes.
  @@unique([name, coachId])
}

model Workout {
  id        String    @id @default(uuid())
  name      String    
  goal      String?   
  level     String?   
  isVisible Boolean   @default(true)
  
  // Planejamento
  startDate DateTime? @default(now()) 
  endDate   DateTime? 
  archived  Boolean   @default(false) 

  // 🔥 NOVO: MODELO DO TREINO (CARGA vs BASE) 🔥
  workoutModel String @default("CARGA")
  
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  createdAt DateTime  @default(now())
}

model WorkoutExercise {
  id          String   @id @default(uuid())
  workoutId   String
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  
  // Exercício Principal
  exerciseId  String
  exercise    Exercise @relation(fields: [exerciseId], references: [id])
  
  // Exercício Substituto (Opcional)
  substituteId String?
  substitute   Exercise? @relation("SubstituteRelation", fields: [substituteId], references: [id])

  restTime    Int      @default(60)
  title       String?  
  sets        Int      @default(3)
  reps        String   @default("12") 
  notes       String?  
  technique   String?  
  day         String   @default("A") 
  order       Int      @default(0) 

  observation String?  
}

model Anamnese {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Dados Físicos
  peso            Float
  altura          Float
  imc             Float?    
  aguaIdeal       Float?    
  
  // Objetivos
  objetivo        String    
  nivel           String    
  
  // Rotina de Treino
  frequencia      Int       
  tempoDisponivel Int      @default(60) 
  
  // Saúde (Arrays)
  limitacoes      String[]  
  cirurgias       String[]  
  equipamentos    String[]  

  // 🔥 NUTRIÇÃO E DIETA (Campos opcionais para o plano Elite) 🔥
  mealsPerDay     Int?      // Quantas vezes prefere comer ao dia (2 a 8)
  allergies       String?   @db.Text // Alergias e Intolerâncias
  foodPreferences String?   @db.Text // Gostos e Preferências
  foodAversions   String?   @db.Text // O que não gosta de comer
  supplements     String?   @db.Text // Suplementos que já utiliza
  wakeUpTime      String?   // Horário que acorda
  sleepTime       String?   // Horário que dorme
  workTime        String?   // Horário de trabalho
  trainTime       String?   // Horário do treino
  
  createdAt       DateTime @default(now())
}

model Diet {
  id            String    @id @default(uuid())
  userId        String    
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  pdfUrl        String?   
  
  name          String    @default("Plano Alimentar")
  goal          String?   
  
  totalKcal     Float?
  totalProtein  Float?
  totalCarbs    Float?
  totalFats     Float?
  
  waterIntake   String?   
  freeMeal      String?   
  generalNotes  String?   @db.Text 
  
  isActive      Boolean   @default(true)
  meals         Meal[]    
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Meal {
  id        String     @id @default(uuid())
  dietId    String
  diet      Diet       @relation(fields: [dietId], references: [id], onDelete: Cascade)
  name      String     
  time      String?    
  order     Int        @default(0) 
  notes     String?    @db.Text 
  // 🔥 ETIQUETA DO TIPO DE DIA (TREINO, CARDIO, DESCANSO)
  dayType   String     @default("TREINO")
  
  items     FoodItem[]
}

model FoodItem {
  id                  String   @id @default(uuid())
  mealId              String
  meal                Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  
  name                String   
  amount              Float    
  unit                String   
  
  protein             Float?
  carbs               Float?
  fats                Float?
  calories            Float?

  substitutionGroupId String?  
}

model TemplateCollection {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#22c55e") 
  createdAt DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachCollections", fields: [coachId], references: [id], onDelete: Cascade)

  templates WorkoutTemplate[]
}

model WorkoutTemplate {
  id        String   @id @default(uuid())
  name      String   
  goal      String   
  level     String   
  data      String   @db.Text 
  createdAt DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachTemplates", fields: [coachId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   TemplateCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

model WorkoutHistory {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name             String   
  workoutName      String? 
  date             DateTime @default(now())
  xpEarned         Int      @default(0)
  duration         Int?     
  progressions     Int      @default(0) 

  rpe              Int?     
  feedback         String?  

  details          ExerciseHistory[]
}

model ExerciseHistory {
  id               String         @id @default(uuid())
  workoutHistoryId String
  workoutHistory   WorkoutHistory @relation(fields: [workoutHistoryId], references: [id], onDelete: Cascade)
  
  exerciseId       String
  exerciseName     String
  
  setNumber        Int
  weight           Float  
  reps             String 
}

model Assessment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  
  weight          Float    
  height          Float?   
  photos          String[] 
  
  neck            Float?   
  shoulders       Float?   
  chest           Float?   
  arms            Float?   
  forearms        Float?   
  waist           Float?   
  abdomen         Float?   
  hips            Float?   
  thighs          Float?   
  calves          Float?   
  
  method          String?  
  
  foldTriceps     Float?
  foldSubscapular Float?
  foldChest       Float?
  foldAxillary    Float?
  foldSuprailiac  Float?
  foldAbdominal   Float?
  foldThigh       Float?
  
  bodyFat         Float?   
  visceralFat     Float?   
  muscleMass      Float?   
  
  notes           String?   
  createdAt       DateTime @default(now())
}

model CheckIn {
  id            String   @id @default(uuid())
  date          DateTime @default(now())
  
  weight        Float?
  feedback      String?  
  
  photoFront    String?  
  photoBack     String?
  coachFeedback String?  
  allowMarketing Boolean @default(false)  
  photoSide     String?
  extraPhotos   String[] 
  
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  active    Boolean  @default(true)
  date      DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachNotices", fields: [coachId], references: [id], onDelete: Cascade)
}

model AiLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model Content {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?  @db.Text
  
  category    String   
  
  type        String   @default("video") 
  isVIP       Boolean  @default(false)   
  
  videoUrl    String?  
  pdfUrl      String?  
  audioUrl    String?  
  thumbUrl    String?  
  duration    String?  
  
  createdAt   DateTime @default(now())

  coachId     String?
  coach       User?    @relation("CoachContents", fields: [coachId], references: [id], onDelete: Cascade)
  
  likes       ContentLike[]
  comments    ContentComment[]
  completions ContentCompletion[] 
  unlockedFor ContentAccess[]
}

model ContentLike {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model ContentComment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}

model ContentCompletion {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}

model ContentAccess {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}

model DietTemplate {
  id          String   @id @default(uuid())
  name        String   
  goal        String?
  totalKcal   Float?
  meals       Json     
  createdAt   DateTime @default(now())
}

model MealTemplate {
  id          String   @id @default(uuid())
  name        String   
  category    String?  
  items       Json     
  createdAt   DateTime @default(now())
}

model DailyCheckin {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      String   
  water_ml  Int      @default(0)
  fome      String?
  digestao  String?
  energia   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

model DietFeedback {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  satiety          String?
  difficulty       String?
  requestedChanges String?  @db.Text
  read             Boolean  @default(false)
  createdAt        DateTime @default(now())
}

// 🔥 MODELO DE PESQUISA DE SATISFAÇÃO (NPS) ATUALIZADO 🔥
model SatisfactionSurvey {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appExperience     String   
  appExpReason      String?  @db.Text 
  
  visualExperience  String?  
  visualReason      String?  @db.Text // Sugestão de nova cor

  toolsExperience   String?  
  toolsReason       String?  @db.Text 
  
  // 🔥 NOVA PERGUNTA: Biblioteca
  libraryExperience String?

  appImprovement    String?  @db.Text 
  coachSupport      String?  @db.Text 
  
  checkinExperience String   
  checkinReason     String?  @db.Text 
  
  // 🔥 NOVAS PERGUNTAS DE DIETA
  dietExperience    String?  @db.Text 
  dietAdherence     String?  
  dietRoutine       String?  // Avaliação da divisão de dias (Treino, Descanso)
  dietTools         String?  // Avaliação de Água e Lista de Mercado
  dietToolsReason   String?  @db.Text // Sugestões para ferramentas da dieta
  dietSubstitutions String?  
  
  createdAt         DateTime @default(now())
  readByAdmin       Boolean  @default(false)
}