// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String
  name              String?
  birthDate         String?
  phone             String?
  cpf               String?
  gender            String?
  aiLogs            AiLog[]
  dailyCheckins     DailyCheckin[]
  dietFeedbacks     DietFeedback[]
  npsRequested      Boolean  @default(false) // Gatilho manual para disparar o NPS
  accountStatus    String  @default("ACTIVE") // ACTIVE, PENDING_APPROVAL, REJECTED
  inviteCode       String? @unique
  coachRequestInfo Json?
  
  // Controle de Acesso e Planos
  plan_tier         String   @default("standard")
  role              String   @default("USER") // ADMIN, USER ou COACH
  plan              String   @default("PERFORMANCE") // FREE, ELITE, VIP
  active            Boolean  @default(true)
  
  // 🔥 INTEGRAÇÃO ASAAS (PAGAMENTOS E ASSINATURAS DO SAAS) 🔥
  asaasCustomerId     String?
  asaasSubscriptionId String?

  // 🔥 PAGAMENTOS DE ALUNOS (COBRANÇAS VIA ASAAS) 🔥
  subscriptions   Subscription[]
  payments        Payment[]

  // 🔥 WHITE-LABEL E CUSTOMIZAÇÃO DO COACH 🔥
  brandLogoUrl        String?
  brandColor          String?

  // 🔥 MODO "VISUALIZAR COMO ALUNO" 🔥
  isTestAccount       Boolean  @default(false) // Identifica se é o aluno fantasma do coach
  
  // 🔥 GESTÃO FINANCEIRA E CONTRATOS 🔥
  contractType      String?   @default("Mensal") // Mensal, Trimestral, Semestral, Anual, Projeto 90, Ficha 8S
  contractValue     Float?    @default(0.0)
  paymentDueDate    DateTime? // Data de Vencimento
  startDate         DateTime? // Data de Início
  nextWorkoutUpdate DateTime? // Data da próxima troca de treino
  financeCategory   String?   @default("Consultoria Online") // 🔥 CATEGORIA INDEPENDENTE NO FINANCEIRO 🔥
  isFinanceActive   Boolean   @default(true)

  // 🔥 SISTEMA DE "JÁ PAGUEI" (CLAIM DE PAGAMENTO PELO ALUNO) 🔥
  paymentClaimedAt         DateTime? // Quando o aluno clicou em "Já paguei"
  paymentClaimStatus       String?   // null | "PENDING" | "REJECTED"
  paymentClaimCycleDueDate DateTime? // Snapshot do paymentDueDate no momento do claim (garante 1x por ciclo)

  // Dados Rápidos (Cache)
  currentWeight   Float? 
  
  // Gamification & Notificações
  currentXP       Int      @default(0)
  pushToken       String?  
  
  // Foto de perfil e Avaliação/Check-in
  photoUrl        String?
  evaluationUrl   String?  
  nextCheckInDate DateTime? 
  disableCheckIn  Boolean  @default(false) 
  dietGoal        String   @default("NONE") 
  goal            String?
  level           String?
  isMenstruating  Boolean   @default(false)
  menstruationStartDate DateTime?

  // 🔥 ANOTAÇÕES PRIVADAS DO COACH E CRM DE ACOMPANHAMENTO 🔥
  strategyNotes   String?   @db.Text
  lastContactDate DateTime?
  weeklyChecks    Json?

  // 🔥 CHAVE DO MÓDULO DE DIETA E ANAMNESE
  dietModule       Boolean  @default(false)
  anamnesePendente Boolean  @default(false) // 🔥 A TRAVA DE ELITE AQUI

  // 🏃 CHAVE DO MÓDULO DE CORRIDA
  runningModule   Boolean  @default(false)

  createdAt       DateTime @default(now())

  // 🔥 MULTI-TENANT (SISTEMA DE MÚLTIPLOS COACHES)
  // Define a qual treinador (de treinos) este aluno pertence
  coachId         String?
  coach           User?    @relation("CoachStudents", fields: [coachId], references: [id], onDelete: SetNull)
  students        User[]   @relation("CoachStudents")

  // 🔥 NOVO: Define a qual NUTRICIONISTA este aluno pertence
  nutritionistId  String?
  nutritionist    User?    @relation("NutritionistStudents", fields: [nutritionistId], references: [id], onDelete: SetNull)
  dietStudents    User[]   @relation("NutritionistStudents")

  // 🔥 CRIAÇÕES EXCLUSIVAS DO COACH (O Muro de Separação)
  createdExercises  Exercise[]          @relation("CoachExercises")
  createdTemplates  WorkoutTemplate[]   @relation("CoachTemplates")
  createdNotices    Notice[]            @relation("CoachNotices")
  createdContents   Content[]           @relation("CoachContents")
  createdCollections TemplateCollection[] @relation("CoachCollections")
  createdTechniques Technique[]         @relation("CoachTechniques") 

  // 🔥 NOVO: Matrizes do Laboratório de IA
  createdMotorTemplates MotorTemplate[] @relation("CoachMotorTemplates")

  // 🔥 ALUNOS OFFLINE DO FINANCEIRO 🔥
  offlineClients    OfflineClient[]     @relation("CoachOfflineClients")

  // Relacionamentos do Aluno
  workouts        Workout[]
  anamneses       Anamnese[]
  history         WorkoutHistory[] 
  assessments     Assessment[]       
  checkIns        CheckIn[]
  diets           Diet[]

  // 🏃 MÓDULO DE CORRIDA
  runningAnamnese   RunningAnamnese?
  runningProtocols  RunningProtocol[]
  runningLogs       RunningLog[] 
  
  // PA FLIX & Comunidade
  contentLikes      ContentLike[]
  contentComments   ContentComment[]
  contentCompletions ContentCompletion[] 
  unlockedContents  ContentAccess[]     

  // Relacionamento de Pesquisas de Satisfação
  surveys           SatisfactionSurvey[]

  resetToken       String?
  resetTokenExpiry DateTime?

  // 🔥 SISTEMA DE ALERTAS IA 🔥
  alertsAsStudent   StudentAlert[] @relation("UserAlerts")
  alertsAsCoach     StudentAlert[] @relation("CoachAlerts")

  // 🔥 WHITE-LABEL E CUSTOMIZAÇÃO 🔥
  brandLogoSize  Int?     @default(220) // 🔥 Mantido aqui, sem duplicar no final

  // 🔥 NOVO: SAAS WHITE-LABEL - PÁGINAS DE VENDAS E PLANOS CUSTOMIZADOS 🔥
  salesPageConfig   SalesPageConfig?
  coachPlans        CoachPlan[]         @relation("CoachPlans")
}


// 🔥 TABELA EXCLUSIVA PARA ALUNOS DO FINANCEIRO (OFFLINE) 🔥
model OfflineClient {
  id              String    @id
  name            String
  phone           String?
  plan            String?
  financeCategory String?   @default("Consultoria Online")
  contractType    String?   @default("Mensal")
  contractValue   Float?    @default(0.0)
  startDate       DateTime?
  paymentDueDate  DateTime?
  photoUrl        String?
  isFinanceActive Boolean   @default(true)
  assignedCoach   String?   // "PAULO" ou "ADRI" para o filtro do App

  coachId         String?
  coach           User?     @relation("CoachOfflineClients", fields: [coachId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Exercise {
  id              String   @id @default(uuid())
  name            String   
  category        String
  subCategory     String?  @default("Geral") 

  howToExecute    String?  @db.Text
  commonMistakes  String?  @db.Text
  maleFocus       String?  @db.Text
  femaleFocus     String?  @db.Text
  
  // 🔥 A NOVA COLUNA DE TAGS DE AMBIENTE 🔥
  environments    String[] @default(["ACADEMIA"])

  // 🔥 NOVA COLUNA ADICIONADA AQUI 🔥
  tags            Json?
  defaultSubstitutes String[] @default([])
  
  videoUrl        String?
  instructions    String?
  createdAt       DateTime @default(now())
  
  // 🔥 ISOLAMENTO: A qual Coach este exercício pertence?
  coachId         String?
  coach           User?    @relation("CoachExercises", fields: [coachId], references: [id], onDelete: Cascade)

  // Relacionamentos
  workoutExercises WorkoutExercise[] 
  asSubstitute     WorkoutExercise[] @relation("SubstituteRelation")

  // 🔥 Permite que a Adri e o Paulo tenham um exercício com o mesmo nome, com vídeos diferentes.
  @@unique([name, coachId])
}

model Workout {
  id        String   @id @default(uuid())
  name      String   
  goal      String?   
  level     String?   
  isVisible Boolean   @default(true)
  
  // Planejamento
  startDate DateTime? @default(now()) 
  endDate   DateTime? 
  archived  Boolean   @default(false) 

  // MODELO DO TREINO (CARGA vs BASE)
  workoutModel String @default("CARGA")

  // 🔥 MOTOR DE PERIODIZAÇÃO (Deload / Choque) 🔥
  intensityMultiplier Float     @default(1.0)
  intensityEndDate    DateTime? 
  
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  createdAt DateTime  @default(now())
}

model WorkoutExercise {
  id                String     @id @default(uuid())
  workoutId         String
  workout           Workout    @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  
  // Exercício Principal
  exerciseId        String
  exercise          Exercise   @relation(fields: [exerciseId], references: [id])
  
  // Exercício Substituto (Opcional - Legado)
  substituteId      String?
  substitute        Exercise?  @relation("SubstituteRelation", fields: [substituteId], references: [id])

  // 🔥 AQUI ESTÁ A COLUNA NOVA PARA OS MÚLTIPLOS SUBSTITUTOS 🔥
  substitutes       String[]   @default([])

  restTime          Int        @default(60)
  title             String?  
  sets              Int        @default(3)
  reps              String     @default("12") 
  notes             String?  
  
  technique         String?    // (MANTÉM PARA RETROCOMPATIBILIDADE DOS TREINOS ANTIGOS)
  
  // 🔥 NOVO: ELO COM A TÉCNICA INTELIGENTE MULTI-STEPS 🔥
  customTechniqueId String?
  customTechnique   Technique? @relation(fields: [customTechniqueId], references: [id], onDelete: SetNull)

  day               String     @default("A") 
  order             Int        @default(0) 

  observation       String?  
}

model Anamnese {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ── DADOS FÍSICOS ──────────────────────────────────────────────────────
  peso            Float
  altura          Float
  imc             Float?
  aguaIdeal       Float?

  // ── OBJETIVOS E NÍVEL ──────────────────────────────────────────────────
  objetivo        String
  nivel           String

  // ── ROTINA DE TREINO ───────────────────────────────────────────────────
  frequencia      Int
  tempoDisponivel Int      @default(60)
  trainFasted     Boolean?

  // ── HISTÓRICO CLÍNICO ──────────────────────────────────────────────────
  limitacoes      String[]
  cirurgias       String[]
  equipamentos    String[]

  // ── SAÚDE METABÓLICA ───────────────────────────────────────────────────
  healthConditions      String[]
  healthConditionsObs   String?   @db.Text
  bariatric             Boolean?
  bariatricType         String?
  bariatricTime         String?
  bariatricIntolerances String[]
  medications           String[]
  medicationsObs        String?   @db.Text

  // ── DIGESTIVO, SONO E STRESS ───────────────────────────────────────────
  digestiveIssues String[]
  digestiveObs    String?   @db.Text
  sleepHours      String?
  sleepQuality    String?
  wakeHungry      Boolean?
  stressLevel     Int?
  stressEating    Boolean?

  // ── CICLO MENSTRUAL (só mulheres) ──────────────────────────────────────
  cycleRegular String?
  pmsSymptoms  String[]
  pmsObs       String?   @db.Text

  // ── ROTINA ALIMENTAR ───────────────────────────────────────────────────
  mealsPerDay        Int?
  wakeUpTime         String?
  sleepTime          String?
  workTime           String?
  workTimeStart      String?
  workTimeEnd        String?
  trainTime          String?
  freeDays             String[]
  freeWakeUpTime       String?
  freeSleepTime        String?
  freeTrainTime        String?
  eatsOutPerWeek     String?
  budget             String?
  preworkoutStrategy String?

  // ── HÁBITOS E HIDRATAÇÃO ───────────────────────────────────────────────
  waterIntake  String?
  alcoholFreq  String?
  coffeePerDay String?
  smoker       Boolean?
  eatSpeed     String?
  nightBinge   String?

  // ── HISTÓRICO DE DIETAS ────────────────────────────────────────────────
  triedDiets       String[]
  dietWorked       String?   @db.Text
  dietHated        String?   @db.Text
  biggestChallenge String?

  // ── PREFERÊNCIAS E SUPLEMENTOS ─────────────────────────────────────────
  allergies       String?   @db.Text
  foodPreferences String?   @db.Text
  foodAversions   String?   @db.Text
  supplements     String?   @db.Text
  extraNotes      String?   @db.Text

  createdAt DateTime @default(now())
}

model Diet {
  id            String   @id @default(uuid())
  userId        String   
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  pdfUrl        String?   
  
  name          String    @default("Plano Alimentar")
  goal          String?   
  
  totalKcal     Float?
  totalProtein  Float?
  totalCarbs    Float?
  totalFats     Float?
  
  waterIntake   String?   
  freeMeal      String?   
  generalNotes  String?   @db.Text 
  
  isActive      Boolean   @default(true)
  meals         Meal[]    
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Meal {
  id        String     @id @default(uuid())
  dietId    String
  diet      Diet       @relation(fields: [dietId], references: [id], onDelete: Cascade)
  name      String     
  time      String?    
  order     Int        @default(0) 
  notes     String?    @db.Text 
  // 🔥 ETIQUETA DO TIPO DE DIA (TREINO, CARDIO, DESCANSO)
  dayType   String     @default("TREINO")

  // 🔥 NOVO — versões alternativas
  alternativeGroupId String?    // refeições com mesmo ID são versões da mesma refeição
  isMainVersion      Boolean    @default(true)  // false = versão alternativa
  alternativeLabel   String?    // ex: "Versão Prática", "Versão Rápida"
  
  items     FoodItem[]
}

model FoodItem {
  id                  String   @id @default(uuid())
  mealId              String
  meal                Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  
  name                String   
  amount              Float    
  unit                String   
  
  protein             Float?
  carbs               Float?
  fats                Float?
  calories            Float?

  substitutionGroupId String?  
}

model TemplateCollection {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#22c55e") 
  createdAt DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachCollections", fields: [coachId], references: [id], onDelete: Cascade)

  templates WorkoutTemplate[]
}

model WorkoutTemplate {
  id        String   @id @default(uuid())
  name      String   
  goal      String   
  level     String   
  data      String   @db.Text 
  createdAt DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachTemplates", fields: [coachId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   TemplateCollection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)
}

// 🔥 MOTOR DE PRESCRIÇÃO: AS MATRIZES INTELIGENTES 🔥
model MotorTemplate {
  id          String   @id @default(uuid())
  name        String   // Ex: "ABCD Feminino Elite"
  
  // Filtros (Tags)
  objectives  String[] // Ex: ["EMAGRECIMENTO", "HIPERTROFIA"]
  levels      String[] // Ex: ["INTERMEDIÁRIO", "AVANÇADO"]
  times       Int[]    // Ex: [45, 60, 90] (Minutos)
  days        Int[]    // Ex: [3, 4] (Dias na semana)
  
  // A Estrutura Lógica (O JSON pesadão que o algoritmo vai ler)
  structure   String   @db.Text 
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  coachId     String?
  coach       User?    @relation("CoachMotorTemplates", fields: [coachId], references: [id], onDelete: Cascade)
}

model WorkoutHistory {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name             String   
  workoutName      String? 
  date             DateTime @default(now())
  xpEarned         Int      @default(0)
  duration         Int?     
  progressions     Int      @default(0) 

  rpe              Int?     
  feedback         String?  

  details          ExerciseHistory[]
}

model ExerciseHistory {
  id               String         @id @default(uuid())
  workoutHistoryId String
  workoutHistory   WorkoutHistory @relation(fields: [workoutHistoryId], references: [id], onDelete: Cascade)
  
  exerciseId       String
  exerciseName     String
  
  setNumber        Int
  weight           Float  
  reps             String 
}

model Assessment {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  
  // 🔥 NOVO: Idade do aluno no exato momento desta avaliação
  age             Int?     
  
  weight          Float    
  height          Float?   
  photos          String[] 
  
  // 🔥 CIRCUNFERÊNCIAS / PERIMETRIA (Todas Opcionais) 🔥
  neck            Float?   
  shoulders       Float?   
  chest           Float?   // Tórax
  waist           Float?   // Cintura
  abdomen         Float?   // Abdômen
  hips            Float?   // Glúteos/Quadril
  
  // Membros Superiores
  arms            Float?   // Braço Direito (Mantido para retrocompatibilidade)
  armLeft         Float?   // Braço Esquerdo
  forearms        Float?   // Antebraço Direito (Mantido para retrocompatibilidade)
  forearmLeft     Float?   // Antebraço Esquerdo
  
  // Membros Inferiores
  thighs          Float?   // Perna Direita (Coxa) (Mantido para retrocompatibilidade)
  thighLeft       Float?   // Perna Esquerda (Coxa)
  calves          Float?   // Panturrilha Direita (Mantido para retrocompatibilidade)
  calfLeft        Float?   // Panturrilha Esquerda
  
  method          String?  
  
  foldTriceps     Float?
  foldSubscapular Float?
  foldChest       Float?
  foldAxillary    Float?
  foldSuprailiac  Float?
  foldAbdominal   Float?
  foldThigh       Float?
  
  bodyFat         Float?   
  visceralFat     Float?   
  muscleMass      Float?   
  
  notes           String?   
  createdAt       DateTime @default(now())
}

model CheckIn {
  id              String   @id @default(uuid())
  date            DateTime @default(now())
  
  weight          Float?
  feedback        String?  
  
  photoFront      String?  
  photoBack       String?
  coachFeedback   String?  
  allowMarketing  Boolean @default(false)  
  photoSide       String?
  extraPhotos     String[]
  photoFrontOriginal  String?
photoSideOriginal   String?
photoBackOriginal   String? 
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  active    Boolean  @default(true)
  date      DateTime @default(now())

  coachId   String?
  coach     User?    @relation("CoachNotices", fields: [coachId], references: [id], onDelete: Cascade)
}

model AiLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  question  String
  answer    String
  createdAt DateTime @default(now())
}

model Content {
  id          String   @id @default(uuid())
  title       String
  subtitle    String?
  description String?  @db.Text
  
  category    String   
  
  type        String   @default("video") 
  isVIP       Boolean  @default(false)   
  
  videoUrl    String?  
  pdfUrl      String?  
  audioUrl    String?  
  thumbUrl    String?  
  duration    String?  
  
  createdAt   DateTime @default(now())

  coachId     String?
  coach       User?    @relation("CoachContents", fields: [coachId], references: [id], onDelete: Cascade)
  
  likes       ContentLike[]
  comments    ContentComment[]
  completions ContentCompletion[] 
  unlockedFor ContentAccess[]
}

model ContentLike {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, contentId])
}

model ContentComment {
  id        String   @id @default(uuid())
  text      String   @db.Text
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  // 🔥 AUTO-RELACIONAMENTO PARA RESPOSTAS (THREADS) 🔥
  parentId  String?
  parent    ContentComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ContentComment[] @relation("CommentReplies")
}

model ContentCompletion {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}

model ContentAccess {
  id        String   @id @default(uuid())
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  contentId String
  content   Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, contentId]) 
}

model DietTemplate {
  id        String   @id @default(uuid())
  name      String   
  goal      String?
  totalKcal Float?
  meals     Json     
  createdAt DateTime @default(now())
}

model MealTemplate {
  id        String   @id @default(uuid())
  name      String   
  category  String?  
  items     Json     
  createdAt DateTime @default(now())
}

model DailyCheckin {
  id        String   @id @default(uuid())
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      String   
  water_ml  Int      @default(0)
  fome      String?
  digestao  String?
  energia   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
}

model DietFeedback {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  satiety          String?
  difficulty       String?
  requestedChanges String?  @db.Text
  read             Boolean  @default(false)
  createdAt        DateTime @default(now())
}

model SatisfactionSurvey {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  appExperience     String   
  appExpReason      String?  @db.Text 
  
  visualExperience  String?  
  visualReason      String?  @db.Text 

  toolsExperience   String?  
  toolsReason       String?  @db.Text 
  
  libraryExperience String?

  appImprovement    String?  @db.Text 
  coachSupport      String?  @db.Text 
  
  checkinExperience String   
  checkinReason     String?  @db.Text 
  
  dietExperience    String?  @db.Text 
  dietAdherence     String?  
  dietRoutine       String?  
  dietTools         String?  
  dietToolsReason   String?  @db.Text 
  dietSubstitutions String?  
  
  createdAt         DateTime @default(now())
  readByAdmin       Boolean  @default(false)
}

// 🔥 NOVO: SISTEMA DE ALERTAS IA (ESTAGNAÇÃO E EVOLUÇÃO) 🔥
model StudentAlert {
  id           String   @id @default(uuid())
  
  // Aluno que gerou o alerta
  userId       String
  user         User     @relation("UserAlerts", fields: [userId], references: [id], onDelete: Cascade)
  
  // Opcional: Treinador dono do alerta (Para o Multi-Tenant)
  coachId      String?
  coach        User?    @relation("CoachAlerts", fields: [coachId], references: [id], onDelete: Cascade)

  type         String   // "STAGNATION", "EVOLUTION", "RISK"
  title        String   // Ex: "Estagnação de Carga"
  message      String   @db.Text // Sugestão gerada pela IA
  exerciseName String?  // Ex: "Agachamento Livre" (caso o alerta seja de um exercício específico)
  
  isRead       Boolean  @default(false) // Para o "Sininho" de notificações do Admin apagar após lido
  createdAt    DateTime @default(now())
}

// ============================================
// 🏃 MÓDULO DE CORRIDA — PROTOCOLO 5K
// ============================================

model RunningAnamnese {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token público para o formulário standalone
  token     String   @unique @default(uuid())
  filled    Boolean  @default(false)
  filledAt  DateTime?

  // 1. Experiência com corrida
  runningExperience   String?  // "never" | "stopped" | "active"
  timeStopped         String?  // Ex: "6 meses"
  maxDistanceBefore   String?  // Ex: "3km"
  weeklyFrequencyNow  String?  // Ex: "0" | "1" | "2" | "3+"
  completedRaces      Boolean  @default(false)
  racesDescription    String?  // Ex: "5k em 2023"

  // 2. Condicionamento atual
  canWalk30min        Boolean  @default(false)
  canJog5min          Boolean  @default(false)
  breathingDifficulty String?  // "light" | "moderate" | "intense"
  fitnessLevel        Int?     // 1 a 5

  // 3. Histórico de lesões e saúde
  injuries            String[] @default([]) // ["Joelho", "Tornozelo", ...]
  heartCondition      Boolean  @default(false)
  jointIssues         Boolean  @default(false)
  medications         String?
  medicalClearance    String?  // "yes" | "no" | "not_consulted"

  // 4. Objetivo e motivação
  runningGoal         String?  // "complete_5k" | "weight_loss" | "fitness" | "race" | "other"
  goalDeadline        String?  // Ex: "3 meses"
  previousFailures    String?  @db.Text

  // 5. Rotina e disponibilidade
  availableDays       String[] @default([]) // ["QUA", "SEX", "DOM"]
  preferredTime       String?  // "morning" | "afternoon" | "evening"
  trainingLocation    String?  // "treadmill" | "street" | "both"
  hasProperShoes      String?  // "yes" | "no" | "not_sure"

  // 6. Informações físicas complementares
  weight              Float?
  height              Float?
  bodyPainDuringWalk  String?  @db.Text
  sleepQuality        String?  // "good" | "regular" | "bad"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RunningProtocol {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String   @default("Protocolo 5K")
  isActive    Boolean  @default(true)
  startDate   DateTime @default(now())

  // Bloco e semana de entrada (definidos pela IA ou pelo admin)
  startBlock  Int      @default(1)  // 1 a 5
  startWeek   Int      @default(1)  // 1 a 8

  // Personalizações geradas pela IA
  customNotes       String?  @db.Text  // Observações específicas para o aluno
  customSpeeds      Json?              // Velocidades ajustadas por zona { z2: 7.5, z3: 8.0, ... }
  adaptations       String?  @db.Text  // Ex: "Substituir intervalado por contínuo na sexta"

  // Controle
  generatedByAI     Boolean  @default(false)
  aiPromptSnapshot  String?  @db.Text  // Snapshot do prompt usado (auditoria)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        RunningLog[]
}

model RunningLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  protocolId  String
  protocol    RunningProtocol @relation(fields: [protocolId], references: [id], onDelete: Cascade)

  // Qual treino da semana
  week        Int              // 1 a 8
  block       Int              // 1 a 5
  sessionDay  String           // "QUARTA" | "SEXTA" | "DOMINGO"

  // Dados registrados pelo aluno
  date             DateTime @default(now())
  durationMinutes  Int?
  distanceKm       Float?
  avgPace          String?  // Ex: "7:30"
  notes            String?  @db.Text

  // Sensação subjetiva (RPE)
  rpe              Int?     // 1 a 10

  createdAt   DateTime @default(now())
}

// 🔥 MÓDULO DE TÉCNICAS CUSTOMIZADAS E MULTI-STEPS 🔥
model Technique {
  id          String   @id @default(uuid())
  name        String   // Ex: "Drop-Pause", "FST-7", "SST"
  description String?  @db.Text
  
  // A Linha do Tempo da Técnica (Onde a mágica acontece)
  // Ex: [{ type: "EXECUTION" }, { type: "DROP", drops: 2 }, { type: "REST_PAUSE", time: 20 }]
  steps       Json
  videoUrl    String?     

  // Permite que o sistema tenha técnicas "Globais" para todos, além das do próprio Coach
  isGlobal    Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Isolamento do Coach
  coachId     String?
  coach       User?    @relation("CoachTechniques", fields: [coachId], references: [id], onDelete: Cascade)

  // Relacionamento com as séries dos treinos
  workoutExercises WorkoutExercise[]
}

model SystemTechniqueVideo {
  id        String   @id @default(uuid())
  key       String   @unique
  videoUrl  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// 💰 MÓDULO DE PAGAMENTOS (ASAAS)
// Fase 1: coach único (Paulo) | Fase 2: multi-tenant com subcontas + split
// ============================================

model PaymentGatewayAccount {
  id            String   @id @default(uuid())
  coachId       String   @unique // Fase 1: sempre o coach principal; Fase 2: um registro por coach
  provider      String   @default("ASAAS")
  asaasApiKey   String   // Key da conta (ou subconta) Asaas do coach
  asaasWalletId String?  // Usado no split de pagamento (Fase 2)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id                  String    @id @default(uuid())
  userId              String
  coachId             String    // A qual coach essa receita pertence
  gatewayAccountId    String
  asaasCustomerId     String    // ID do cliente (aluna) no Asaas
  asaasSubscriptionId String?   // ID da assinatura no Asaas (null se cobrança avulsa)
  planName            String    // Ex: "Mensal", "Trimestral", "Anual"
  value               Float
  cycle               String    @default("MONTHLY") // MONTHLY, QUARTERLY, SEMIANNUALLY, YEARLY
  billingType         String    @default("UNDEFINED") // PIX, CREDIT_CARD, BOLETO, UNDEFINED (aluna escolhe)
  status              String    @default("ACTIVE") // ACTIVE, OVERDUE, CANCELED
  nextDueDate         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  gatewayAccount PaymentGatewayAccount @relation(fields: [gatewayAccountId], references: [id])
  payments       Payment[]

  @@index([userId])
  @@index([coachId])
}

model Payment {
  id               String    @id @default(uuid())
  subscriptionId   String?
  userId           String
  coachId          String    // A qual coach essa receita pertence
  gatewayAccountId String
  asaasPaymentId   String    @unique // ID da cobrança no Asaas (chave do webhook)
  value            Float
  netValue         Float?    // Valor líquido após taxa Asaas (vem no webhook)
  billingType      String    // PIX, CREDIT_CARD, BOLETO, UNDEFINED
  status           String    @default("PENDING") // PENDING, CONFIRMED, RECEIVED, OVERDUE, REFUNDED, CANCELED
  dueDate          DateTime
  paymentDate      DateTime?
  invoiceUrl       String?   // Link da fatura Asaas (aluna escolhe forma de pagamento lá)
  pixQrCode        String?   @db.Text // Imagem base64 do QR Code PIX
  pixCopyPaste     String?   @db.Text // Código copia-e-cola do PIX
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  subscription   Subscription?         @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  gatewayAccount PaymentGatewayAccount @relation(fields: [gatewayAccountId], references: [id])

  @@index([userId])
  @@index([coachId])
  @@index([asaasPaymentId])
}

// 🔥 NOVO: PÁGINA DE VENDAS DO COACH 🔥
model SalesPageConfig {
  id              String   @id @default(uuid())
  
  coachId         String   @unique
  coach           User     @relation(fields: [coachId], references: [id], onDelete: Cascade)
  
  pageTitle       String?  @default("Minha Consultoria")
  aboutText       String?  @db.Text
  videoUrl        String?  // Link de um vídeo pitch (YouTube, Vimeo)
  coachPhotoUrl   String?  // 🔥 NOVO: Foto de perfil para autoridade
  galleryPhotos   String[] @default([]) // Array de URLs (Antes e Depois)

// 🔥 NOVOS CAMPOS PARA TEXTOS E DEPOIMENTOS:
  galleryTexts      String[] @default([]) // A historinha do antes e depois
  testimonialNames  String[] @default([]) // Nome do aluno do depoimento
  testimonialTexts  String[] @default([]) // O texto do depoimento

  themeColor      String?  @default("#4DE38F") // Cor principal da página
  appFeatures     String[] @default([]) // Funcionalidades que ele quer mostrar
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// 🔥 NOVO: PLANOS CUSTOMIZADOS DO COACH 🔥
model CoachPlan {
  id               String   @id @default(uuid())
  
  coachId          String
  coach            User     @relation("CoachPlans", fields: [coachId], references: [id], onDelete: Cascade)
  
  name             String   // Ex: "Projeto Verão 90 Dias"
  description      String?  @db.Text
  value            Float    // Valor original
  promotionalValue Float?   // Se preenchido, é o valor com desconto
  durationInMonths Int      @default(1) // 1 = Mensal, 3 = Trimestral, etc
  discountPerc     Int      @default(0)
  isActive         Boolean  @default(true)
  isPromoActive    Boolean  @default(false)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}