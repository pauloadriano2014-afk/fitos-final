// prisma/schema/config.prisma

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["prismaSchemaFolder"] // 🔥 ATIVA O SUPORTE A MÚLTIPLOS ARQUIVOS
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model PlatformConfig {
  id              String   @id @default("singleton")
  launchPromoUsed Int      @default(0)
  launchPromoMax  Int      @default(10)
  updatedAt       DateTime @updatedAt
}